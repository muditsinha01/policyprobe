# PolicyProbe Environment Configuration
#
# Copy this file to .env and fill in your values

# OpenRouter API Key (required for LLM features)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model (optional, defaults to meta-llama/llama-3-70b-instruct for demo)
# See available models at: https://openrouter.ai/models
# For demo purposes, Llama 3 70B Instruct is recommended as it's more permissive with PII
OPENROUTER_MODEL=meta-llama/llama-3-70b-instruct

# DeepSeek API Key (used for LLM-based PII redaction verification)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# JWT Secret (used after Unifai remediation for agent auth)
JWT_SECRET=your_jwt_secret_here

# Backend URL (for frontend to connect)
BACKEND_URL=http://localhost:8000

# Mock PyPI Registry URL (for Dependency Research Agent demo)
# Run: python scripts/mock_pypi_registry.py
# Then set this so the agent queries the mock registry instead of real PyPI
# MOCK_PYPI_URL=http://localhost:8888

# Optional: Logging level
LOG_LEVEL=INFO
